{
    "$schema": "https://raw.githubusercontent.com/nicehash/tauri/tauri-v2/crates/tauri-cli/schema.json",
    "productName": "My Little Mind Map",
    "identifier": "com.mylittlemindmap.desktop",
    "version": "0.1.0",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:1420",
        "beforeDevCommand": "pnpm dev:fe",
        "beforeBuildCommand": "pnpm build:fe"
    },
    "app": {
        "windows": [
            {
                "title": "My Little Mind Map",
                "width": 1024,
                "height": 768
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}