{
    "$schema": "../gen/schemas/desktop-schema.json",
    "identifier": "default",
    "description": "Default capabilities for the desktop app",
    "windows": ["main"],
    "permissions": [
        "dialog:allow-open",
        "upload:allow-upload",
        {
            "identifier": "fs:allow-read-file",
            "allow": [{"path": "$HOME/**"}]
        },
        "core:default"
    ]
}
